{
  "info": {
    "_postman_id": "9e3b7a5f-a977-405a-ab9c-2c0a0a5d24c5",
    "name": "Ecommerce API - Auth & Token Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
